{
  "homepage": "https://github.com/groton-school/canvas-cli#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/groton-school/canvas-cli.git"
  },
  "author": {
    "name": "Seth Battis",
    "email": "sbattis@groton.org"
  },
  "type": "module",
  "scripts": {
    "build": "run-s build:*",
    "build:paths": "monorepo-package-paths -w --repository --homepage --author",
    "build:compile": "lerna run build",
    "release": "run-s release:*",
    "release:build": "run-s build",
    "release:git": "git push --follow-tags",
    "release:login": "pnpm login",
    "release:publish": "pnpm publish -r --access public"
  },
  "devDependencies": {
    "@battis/eslint-config": "^2.1.0",
    "@battis/prettier-config": "^1.7.3",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/config-pnpm-scopes": "^20.4.3",
    "@groton/canvas-cli": "workspace:*",
    "@msar/canvas-import": "workspace:*",
    "lerna": "^8.2.4",
    "monorepo-package-paths": "^0.4.4",
    "npm-run-all": "^4.1.5"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
