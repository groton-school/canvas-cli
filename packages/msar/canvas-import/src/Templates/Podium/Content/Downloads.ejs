<% if (content.Content.length > 0 || (content.FilePath &&
content.FilePath.canvas)) { %>
<div>
  <% if (!content.FilePath || !content.FilePath.canvas) { %>
  <h3>Downloads</h3>
  <dl>
    <% for (const item of content.Content) { %>
    <dt>
      <% if (item.DownloadUrl.canvas) { %>
      <%- include('../../Canvas/FileLink', {instance_url, course_id, file: item.DownloadUrl.canvas, filename: item.Description}) %>
      <% } else if (item.DownloadUrl.error) { %>
      <p class="code">Error: <%= item.DownloadUrl.error %></p>
      <% } else { %>
      <p class="code">
        Error: No Canvas upload associated with this link (<%=
        item.DownloadUrl.original %>)
      </p>
      <% }%>
    </dt>
    <dd><%- item.LongDescription %></dd>
    <% } %>
  </dl>
  <% } else { %>
  <dl>
    <dt>
      <% if (content.FilePath.canvas) { %>
      <%- include('../../Canvas/FileLink', {instance_url, course_id, file: content.FilePath.canvas, filename: content.ShortDescription}) %>
      <% } else if (content.FilePath.error) { %>
      <p class="code">Error: <%= content.FilePath.error %></p>
      <% } else { %>
      <p class="code">
        Error: No Canvas upload associated with this link (<%=
        content.FilePath.original %>)
      </p>
      <% }%>
    </dt>
    <dd><%- content.LongDescription %></dd>
  </dl>
  <% } %>
</div>
<% } %>
